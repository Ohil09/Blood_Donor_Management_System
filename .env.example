# ─────────────────────────────────────────────
# BDMS — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# Flask Core
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=CHANGE_ME_to_a_long_random_string_at_least_32_chars

# MongoDB
# Local development:
MONGO_URI=mongodb://localhost:27017/bdms_dev
# OR MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/bdms_prod?retryWrites=true&w=majority
MONGO_DB_NAME=bdms_dev

# Flask-Mail (Email Notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com

# Twilio SMS (Optional — leave blank to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Low Stock Threshold (units)
LOW_STOCK_THRESHOLD=5

# Eligibility Windows (days)
WHOLE_BLOOD_INTERVAL=56
PLATELET_INTERVAL=7
PLASMA_INTERVAL=28